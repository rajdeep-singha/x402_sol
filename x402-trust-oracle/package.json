{
  "name": "x402-trust-oracle",
  "version": "1.0.0",
  "description": "x402-Gated Counterparty Trust Oracle on Solana",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "lint": "eslint src/**/*.ts",
    "test": "jest"
  },
  "dependencies": {
    "@covalenthq/client-sdk": "^3.0.6",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@x402/core": "^2.11.0",
    "@x402/evm": "^2.11.0",
    "@x402/fetch": "^2.11.0",
    "axios": "^1.16.0",
    "bs58": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "graphql-ws": "^6.0.8",
    "viem": "^2.48.4",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.17",
    "@types/node-fetch": "^2.6.13",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "moduleNameMapper": {
      "^(.{1,2}/.*).js$": "$1"
    }
  }
}
